aws_region     = "us-east-1"
project_name   = "ai-cicd"
environment    = "production"
instance_type  = "t3.small"
ssh_public_key = "ssh-ed25519 AAAA... your-public-key"
# Restrict SSH to your IP in production
allowed_cidr = "203.0.113.10/32"

# Optional: private GHCR image
ghcr_username = "github-username"
ghcr_token    = "ghp_..." # read:packages
app_image     = "ghcr.io/your-org/your-repo:main"
